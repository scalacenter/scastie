# The code must remain inside the curly brackets.
msgid "help.worksheet_description"
msgstr "Habilitado por padrão, o modo Planilha da o valor e o tipo de cada linha do seu programa. você pode também adicionar blocos HTML como: {html"<h1>Olá</h1>"} para a renderizar próximo a declaração."

msgid "help.worksheet_packages_warning"
msgstr "No modo Planilha você não pode usar pacotes. Se você quiser usar, desligue o Modo e adicione um metódo principal e afirmações de println."

